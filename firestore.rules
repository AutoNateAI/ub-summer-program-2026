rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsStudent(studentId) {
      return signedIn() && request.auth.uid == studentId;
    }

    function ownsExisting() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "autonate.ai@gmail.com";
    }

    function validWeekendQuizResponse() {
      return request.resource.data.quizId == "weekend-checkpoint-days-1-3"
        && request.resource.data.name is string
        && request.resource.data.nameKey is string
        && request.resource.data.email is string
        && request.resource.data.answers is map
        && request.resource.data.answeredCount is int
        && request.resource.data.score is int
        && request.resource.data.totalPoints == 30
        && request.resource.data.submitted is bool
        && request.resource.data.dueLabel is string;
    }

    match /weekendQuizResponses/{responseId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if validWeekendQuizResponse();
      allow delete: if isAdmin();
    }

    match /opportunityReports/{reportId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /campaigns/{campaignId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /touchpoints/{touchpointId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /savedFilters/{filterId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /contacts/{contactId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /mapSnapshots/{snapshotId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /githubRepos/{repoId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /aiWorkflows/{workflowId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /cohorts/{cohortId}/students/{studentId} {
      allow read, create, update: if ownsStudent(studentId);
      allow delete: if false;

      match /programIdeas/{ideaId} {
        allow read, create, update, delete: if ownsStudent(studentId);
      }

      match /homework/{submissionId} {
        allow read, create, update, delete: if ownsStudent(studentId);
      }

      match /stats/{statId} {
        allow read: if ownsStudent(studentId);
        allow write: if false;
      }
    }
  }
}
